{
  "name": "kids-chore-tracker-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:vendor && npm run build:static",
    "build:static": "node scripts/build-static-site.mjs",
    "build:vendor": "node scripts/build-supabase-vendor.mjs",
    "test": "node --test tests/regression/*.test.mjs",
    "test:regression": "node --test tests/regression/*.test.mjs",
    "test:supabase": "node scripts/test-supabase-connection.mjs",
    "feedback:import": "node scripts/import-feedback.mjs",
    "ci:secret-guard": "node scripts/ci-secret-guard.mjs",
    "token:report": "node scripts/token-metrics.mjs report",
    "token:baseline": "node scripts/token-metrics.mjs baseline --out scripts/token-baseline.json",
    "token:budget:init": "node scripts/token-metrics.mjs init-budget --out scripts/token-budgets.json",
    "token:gate": "node scripts/token-metrics.mjs gate --budget scripts/token-budgets.json"
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "jsdom": "^29.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1"
  }
}
