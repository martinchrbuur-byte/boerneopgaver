# Supabase Configuration

SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_ACCESS_TOKEN=your_personal_access_token_here

# Spotify Integration (Edge Functions)
SPOTIFY_CONNECT_URL=https://<project-ref>.supabase.co/functions/v1/spotify-connect
SPOTIFY_RECOMMENDATIONS_ENDPOINT=https://<project-ref>.supabase.co/functions/v1/spotify-recommendations
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/spotify-callback
SPOTIFY_SCOPES=user-read-email user-read-private
SPOTIFY_STATE_SECRET=replace_with_a_long_random_value
SPOTIFY_POST_AUTH_REDIRECT_URL=https://<your-app-origin>/
